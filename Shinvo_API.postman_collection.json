								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"public_id\": \"shinvo-ecommerce/your_image_public_id\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/upload",
							"host": ["{{baseUrl}}"],
							"path": ["api", "upload"]
						},
						"description": "Delete an image from Cloudinary by its public_id."
					}
				}
			]
		}
	]
}

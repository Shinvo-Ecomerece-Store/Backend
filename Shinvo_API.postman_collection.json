					}
				}
			]
		},
		{
			"name": "📦 Products",
			"item": [
				{
					"name": "Get All Products",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.products && jsonData.products.length > 0) {",
									"    pm.collectionVariables.set('productId', jsonData.products[0]._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/products",
							"host": ["{{baseUrl}}"],
							"path": ["api", "products"]
						},
						"description": "Get all products with pagination. First product ID is auto-saved."
					}
				},
				{
					"name": "Get All Products (with Filters)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/products?search=samsung&minPrice=1000&maxPrice=10000&sort=price_asc&page=1&limit=5",
							"host": ["{{baseUrl}}"],
							"path": ["api", "products"],
							"query": [
								{ "key": "search", "value": "samsung" },
								{ "key": "minPrice", "value": "1000" },
								{ "key": "maxPrice", "value": "10000" },
								{ "key": "sort", "value": "price_asc", "description": "Options: price_asc, price_desc, rating, name" },
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "5" }
							]
						},
						"description": "Get products with search, price filter, sort, and pagination."
